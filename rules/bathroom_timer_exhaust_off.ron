Rule(
    id: "ba000001-0005-0005-0005-000000000005",
    name: "Bathroom - Timer Fires, Exhaust Off",
    enabled: true,
    priority: 10,
    tags: [],
    trigger: DeviceStateChanged(
        device_id: "timer_bathroom",
        attribute: Some("state"),
    ),
    conditions: [
        DeviceState(
            device_id: "timer_bathroom",
            attribute: "state",
            op: Eq,
            value: "finished",
        ),
    ],
    actions: [
        RuleAction(
            enabled: true,
            action: SetDeviceState(
                device_id: "lutron_21",
                state: {
                    "on": false,
                },
                track_event_value: false,
            ),
        ),
    ],
    log_events: false,
    log_triggers: false,
    log_actions: false,
    cancel_on_false: false,
)