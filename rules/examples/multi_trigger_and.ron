Rule(
    id: "a1b2c3d4-0011-0011-0011-000000000011",
    name: "Multi-Trigger AND — Door Open While Away",
    enabled: false,
    priority: 10,
    tags: [],
    trigger: DeviceStateChanged(
        device_id: "sensor.door_front",
        attribute: Some("open"),
    ),
    conditions: [
        DeviceState(
            device_id: "sensor.door_front",
            attribute: "open",
            op: Eq,
            value: true,
        ),
        DeviceState(
            device_id: "switch.away_mode",
            attribute: "on",
            op: Eq,
            value: true,
        ),
    ],
    actions: [
        RuleAction(
            enabled: true,
            action: Notify(
                channel: "pushover",
                message: "Front door opened while house is in Away mode.",
                title: Some("Security Alert"),
            ),
        ),
    ],
    log_events: false,
    log_triggers: false,
    log_actions: false,
    cancel_on_false: false,
)