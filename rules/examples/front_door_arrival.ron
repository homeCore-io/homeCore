Rule(
    id: "a1b2c3d4-0002-0002-0002-000000000002",
    name: "Front Door Arrival Lights",
    enabled: false,
    priority: 20,
    tags: [],
    trigger: DeviceStateChanged(
        device_id: "sensor.front_door",
        attribute: Some("contact"),
    ),
    conditions: [
        TimeWindow(
            start: "18:00:00",
            end: "23:30:00",
        ),
        DeviceState(
            device_id: "sensor.front_door",
            attribute: "contact",
            op: Eq,
            value: true,
        ),
    ],
    actions: [
        RuleAction(
            enabled: true,
            action: SetDeviceState(
                device_id: "light.entryway",
                state: {
                    "brightness": 255,
                    "on": true,
                },
                track_event_value: false,
            ),
        ),
        RuleAction(
            enabled: true,
            action: Notify(
                channel: "pushover",
                message: "Front door opened",
                title: Some("Arrival"),
            ),
        ),
        RuleAction(
            enabled: true,
            action: Delay(
                duration_secs: 300,
                cancelable: false,
            ),
        ),
        RuleAction(
            enabled: true,
            action: SetDeviceState(
                device_id: "light.entryway",
                state: {
                    "on": false,
                },
                track_event_value: false,
            ),
        ),
    ],
    log_events: false,
    log_triggers: false,
    log_actions: false,
    cancel_on_false: false,
)