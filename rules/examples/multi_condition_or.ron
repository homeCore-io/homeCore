Rule(
    id: "a1b2c3d4-0012-0012-0012-000000000012",
    name: "Multi-Condition OR — Office Air Quality Exhaust",
    enabled: false,
    priority: 10,
    tags: [],
    trigger: DeviceStateChanged(
        device_id: "sensor.office_th",
    ),
    conditions: [
        ScriptExpression(
            script: "  let t = device_state(\"sensor.office_th\")[\"temperature\"];\n  let h = device_state(\"sensor.office_th\")[\"humidity_pct\"];\n  t > 78.0 || h > 75.0\n",
        ),
    ],
    actions: [
        RuleAction(
            enabled: true,
            action: SetDeviceState(
                device_id: "switch.office_exhaust",
                state: {
                    "on": true,
                },
                track_event_value: false,
            ),
        ),
    ],
    log_events: false,
    log_triggers: false,
    log_actions: false,
    cancel_on_false: false,
)