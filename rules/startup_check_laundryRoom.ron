Rule(
    id: "c829dc15-e7d7-48c4-9fcc-8f757d8d7ab6",
    name: "Startup Check - Laundry Room Door Open",
    enabled: false,
    priority: 5,
    tags: [
        "garage",
        "door-alerts",
        "startup",
    ],
    trigger: SystemStarted,
    conditions: [
        DeviceState(
            device_id: "yolink_d88b4c0200142e3c",
            attribute: "open",
            op: Eq,
            value: true,
        ),
    ],
    actions: [
        RuleAction(
            enabled: true,
            action: Notify(
                channel: "telegram",
                message: "Laundry room door was open when homeCore started",
                title: None,
            ),
        ),
    ],
    log_events: false,
    log_triggers: false,
    log_actions: false,
    cancel_on_false: false,
)