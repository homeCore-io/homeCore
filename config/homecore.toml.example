# HomeCore configuration file
#
# BASE DIRECTORY
# ==============
# HomeCore uses a single installation directory for all files — config,
# data, logs, and profiles.  The intended model is:
#
#   cd /opt/homecore        (or wherever the package was installed)
#   ./bin/homecore          (binary reads everything relative to here)
#
# The base directory is determined at startup in this order:
#   1. --home <path>          command-line argument
#   2. HOMECORE_HOME          environment variable
#   3. Current working directory of the process (default)
#
# The config file itself is located at:
#   {base_dir}/config/homecore.toml   (default)
#   --config <path>                   command-line override
#   HOMECORE_CONFIG                   environment variable override
#
# Standard directory layout (created automatically on first run):
#   config/           this file and homecore.toml
#   config/profiles/  ecosystem device profiles (Shelly, Tasmota, etc.)
#   data/             state.redb and history.db
#   logs/             rolling log files (when file logging is enabled)

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
[server]
host = "0.0.0.0"
port = 8080

# ---------------------------------------------------------------------------
# Embedded MQTT broker
#
# Authentication: when [[broker.clients]] entries are present the broker
# requires every client to authenticate with matching credentials.
# The internal core client must always be listed when auth is enabled.
#
# TLS: set tls_port + cert_path + key_path to add a TLS listener.
# cert_path and key_path may be absolute or relative to base_dir.
# Generate a self-signed cert:
#   openssl req -x509 -newkey rsa:4096 -keyout broker.key -out broker.crt \
#               -days 3650 -nodes -subj "/CN=homecore-broker"
# ---------------------------------------------------------------------------
[broker]
host = "0.0.0.0"
port = 1883
# MQTT v5 listener (used by newer devices / Shelly Gen2/Gen3).  Set to null to disable.
# v5_port = 1884
# tls_port = 8883
# cert_path = "config/broker.crt"   # relative to base_dir
# key_path  = "config/broker.key"   # relative to base_dir

# Internal core client — required when authentication is enabled.
# [[broker.clients]]
# id       = "internal.core"
# password = "change-me-internal-password"
# allow_pub = ["homecore/#"]
# allow_sub = ["homecore/#"]

# Example plugin entry.
# [[broker.clients]]
# id       = "plugin.zigbee"
# password = "plugin-zigbee-password"
# allow_pub = ["homecore/devices/zigbee_+/state", "homecore/plugins/zigbee/+"]
# allow_sub = ["homecore/devices/zigbee_+/cmd"]

# Cross-device consumer plugin (e.g. hc-thermostat) — needs to read state from
# OTHER plugins' devices and publish commands to them. Broader ACL required:
# [[broker.clients]]
# id       = "plugin.thermostat"
# password = "plugin-thermostat-password"
# allow_pub = [
#     "homecore/devices/thermostat_+/state",       # own thermostat state
#     "homecore/devices/+/cmd",                    # commands to any actuator
#     "homecore/plugins/plugin.thermostat/+",      # heartbeat, logs
# ]
# allow_sub = [
#     "homecore/devices/thermostat_+/cmd",         # own command topic
#     "homecore/devices/+/state",                  # read all sensors
#     "homecore/plugins/plugin.thermostat/manage/cmd",
# ]

# ---------------------------------------------------------------------------
# Location  (used for sunrise/sunset calculations)
# ---------------------------------------------------------------------------
[location]
latitude  = 38.9072
longitude = -77.0369
# timezone is informational only; the local system timezone is used at runtime
timezone  = "America/New_York"

# ---------------------------------------------------------------------------
# Battery alerts
# ---------------------------------------------------------------------------
# Synthesizes `device.battery_low` / `device.battery_recovered` events from
# device state changes, with hysteresis (latches at threshold_pct, clears at
# threshold_pct + recover_band_pct). Rules can react via the matching
# triggers; see core/rules/examples/battery_low_notify.ron.
[battery]
threshold_pct    = 20.0
recover_band_pct = 5.0
# Optional built-in notify shortcut. If set, a notification is sent on each
# low edge using the named hc-notify channel — no rule required. Leave unset
# to keep notifications strictly rule-driven.
# notify_channel       = "all"
# Recovery edges are typically less actionable; opt in explicitly.
# notify_on_recovered  = false

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
[auth]
# HMAC-SHA256 secret for signing JWTs.
#
# Leave unset to let the core manage a persistent secret file automatically
# (default path: `<parent-of-state_db_path>/jwt_secret`, 0600). The file is
# generated once on first startup and reused across restarts, so issued
# tokens survive reboots.
#
# `jwt_secret` (inline) still works but is deprecated; prefer `jwt_secret_file`.
# jwt_secret      = "change-me-to-a-long-random-string-before-deploying"
# jwt_secret_file = "/var/lib/homecore/jwt_secret"
token_expiry_hours = 24

# IP whitelist — addresses that bypass JWT authentication entirely.
# Requests from these IPs receive full Admin access without a token.
# Both IPv4 and IPv6 CIDR notation are supported.  A bare address without
# a prefix length is treated as a host route (/32 or /128).
#
# Use cases:
#   - Localhost-only scripts and dashboards on the same machine
#   - Trusted LAN subnet (home network) for direct device control
#   - Internal automation services that can't carry tokens
#
# WARNING: anyone on a whitelisted network gets unrestricted Admin access.
# Do not whitelist ranges that include untrusted hosts.
#
# whitelist = [
#   "127.0.0.1/32",      # localhost IPv4
#   "::1/128",           # localhost IPv6
#   "192.168.1.0/24",    # home LAN
# ]

# ---------------------------------------------------------------------------
# Storage
#
# Paths may be absolute or relative to base_dir.
# When omitted, defaults are:
#   state_db_path   = {base_dir}/data/state.redb
#   history_db_path = {base_dir}/data/history.db
# ---------------------------------------------------------------------------
[storage]
# state_db_path   = "data/state.redb"    # relative to base_dir (default)
# history_db_path = "data/history.db"    # relative to base_dir (default)

# ---------------------------------------------------------------------------
# Automation rules
#
# Each rule lives in its own TOML file.  The filename (minus .toml) is the
# rule's slug; the `name` field inside the file is the human display name.
# Changes to files are hot-reloaded automatically — no restart required.
# Validation runs before any swap; parse errors leave the running rules intact.
# ---------------------------------------------------------------------------
[rules]
# dir = "rules"    # relative to base_dir (default)

# ---------------------------------------------------------------------------
# Ecosystem profiles
#
# Directory containing device ecosystem profile TOML files.
# Path may be absolute or relative to base_dir.
# Default: {base_dir}/config/profiles
# ---------------------------------------------------------------------------
[profiles]
# dir = "config/profiles"    # relative to base_dir (default)

# ---------------------------------------------------------------------------
# Logging
#
# Three independent outputs run simultaneously.  Each can be enabled or
# disabled individually with its own format and level filter.
#
# Log levels:  error | warn | info | debug | trace
# Formats:     pretty | compact | json
# ---------------------------------------------------------------------------
[logging]
level = "info"

# Per-crate overrides.  Keys are Rust target names (hyphens → underscores).
# Equivalent to RUST_LOG directives but set permanently in config.
# RUST_LOG env var still works and takes highest precedence on top of these.
[logging.targets]
# hc_core        = "debug"
# hc_mqtt_client = "debug"
# hc_broker      = "warn"
# hc_api         = "info"
# hc_state       = "info"
# hc_topic_map   = "debug"

# Stderr output (enabled by default)
[logging.stderr]
enabled = true
format  = "pretty"   # pretty | compact | json
ansi    = true       # set false when piping to systemd journal / Docker logs

# Rolling file output (enabled by default)
# dir may be absolute or relative to base_dir.  Default: {base_dir}/logs
[logging.file]
enabled  = true
# dir    = "logs"          # relative to base_dir (default)
prefix           = "homecore"  # log files named homecore.YYYY-MM-DD
rotation         = "daily"     # daily | hourly | never
prune_after_days = 5           # delete rotated logs older than N days (0 = never prune)
format           = "json"      # json recommended for files (structured, parseable)

# Dedicated rule/automation log (disabled by default).
# When enabled, writes ONLY hc_core (engine/executor/scheduler) debug logs to a
# separate file — clean audit trail of every trigger, condition, and action.
# [logging.rules_file]
# enabled  = true
# dir      = "logs"       # defaults to same dir as [logging.file]
# prefix   = "rules"      # files named rules.YYYY-MM-DD
# rotation = "daily"
# prune_after_days = 5    # delete rotated logs older than N days (0 = never)
# format   = "pretty"     # "json" recommended for log aggregators

# Remote syslog output (disabled by default)
# Supports UDP (recommended) or TCP; RFC 3164 or RFC 5424.
[logging.syslog]
enabled   = false
transport = "udp"          # udp | tcp
host      = "192.168.1.100"
port      = 514
protocol  = "rfc5424"      # rfc5424 | rfc3164
facility  = "daemon"       # kern user mail daemon auth syslog local0-local7
app_name  = "homecore"
# level = "warn"           # syslog-only level override (defaults to [logging].level)

# ---------------------------------------------------------------------------
# Plugins
#
# HomeCore spawns each enabled plugin as a child process and supervises it
# with exponential-backoff restarts (2 s → 4 → 8 → … → 60 s max).
# Paths may be absolute or relative to base_dir.
# ---------------------------------------------------------------------------

[[plugins]]
id      = "plugin.yolink"
binary  = "plugins/hc-yolink/bin/hc-yolink"
config  = "plugins/hc-yolink/config/config.toml"
enabled = true

[[plugins]]
id      = "plugin.lutron"
binary  = "plugins/hc-lutron/bin/hc-lutron"
config  = "plugins/hc-lutron/config/config.toml"
enabled = true

[[plugins]]
id      = "plugin.sonos"
binary  = "plugins/hc-sonos/bin/hc-sonos"
config  = "plugins/hc-sonos/config/config.toml"
enabled = true

[[plugins]]
id      = "plugin.zwave"
binary  = "plugins/hc-zwave/bin/hc-zwave"
config  = "plugins/hc-zwave/config/config.toml"
enabled = true

[[plugins]]
id      = "plugin.hue"
binary  = "plugins/hc-hue/bin/hc-hue"
config  = "plugins/hc-hue/config/config.toml"
enabled = false

[[plugins]]
id      = "plugin.matter"
binary  = "plugins/hc-matter/bin/hc-matter"
config  = "plugins/hc-matter/config/config.toml"
enabled = false

# ---------------------------------------------------------------------------
# Notifications
#
# Named channels used by `Notify` rule actions.  The `name` field is what
# you reference in rules: `channel = "telegram"`.
# `channel = "all"` fans out to every registered channel.
#
# Supported types: telegram | pushover | email
#
# Telegram setup:
#   1. Message @BotFather on Telegram → /newbot → get token
#   2. Send a message to your new bot
#   3. GET https://api.telegram.org/bot<TOKEN>/getUpdates → find chat.id
#   Group/channel IDs are negative integers; personal chat IDs are positive.
# ---------------------------------------------------------------------------
# [[notify.channels]]
# name      = "telegram"
# type      = "telegram"
# bot_token = "123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
# chat_id   = "-100123456789"   # group/channel (negative) or user ID (positive)
# markdown  = false             # optional: enable MarkdownV2 formatting

# [[notify.channels]]
# name      = "pushover"
# type      = "pushover"
# app_token = "azGDORePK8gMaC0QOYAMyEEuzJnyUi"
# user_key  = "uQiRzpo4DXghDmr9QzzfQu27cmVRsG"

# [[notify.channels]]
# name          = "email"
# type          = "email"
# smtp_host     = "smtp.example.com"
# smtp_port     = 587
# username      = "homecore@example.com"
# password      = "smtp-app-password"
# from          = "homecore@example.com"
# to            = ["you@example.com"]

# ---------------------------------------------------------------------------
# Topic maps for non-standard devices (Tasmota, Shelly, ESPHome, etc.)
# ---------------------------------------------------------------------------
# [[topic_map]]
# source_pattern  = "stat/{device}/POWER"
# target_template = "homecore/devices/tasmota_{device}/state"
# transform       = "tasmota_power_to_state"

# [[topic_map]]
# source_pattern     = "shellies/{device}/relay/0"
# target_template    = "homecore/devices/shelly_{device}/state"
# transform          = "shelly_relay_to_state"
# cmd_source_pattern = "homecore/devices/shelly_{device}/cmd"
# cmd_target_template= "shellies/{device}/relay/0/command"
# cmd_transform      = "homecore_cmd_to_shelly_relay"
