# Generated by Cargo
# will have compiled files and executables
tmp.md
debug/
target/
let
# Runtime dashboard store — written by hc-api on every dashboard
# edit, same category as state.redb / history.db (which are already
# covered by *.redb / *.db). The seed code returns
# DashboardStoreData::default() when this file is missing, so a fresh
# checkout starts with a clean dashboard set.
data/dashboards.json

# Ignore rules
rules/

config/homecore.dev.toml.example
# Ignore plugins
plugins/hc-yolink/
plugins/hc-lutron/
plugins/hc-sonos/
plugins/hc-sonos/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover / JetBrains IDE
.idea/

# Claude Code session files
.claude/

# Temporary files
*.tmp
*.bak
*.swp

# Runtime databases (redb + SQLite, including WAL sidecars)
*.redb
*.db
*.db-wal
*.db-shm
*.db-journal

# Private keys, certificates, secrets
*.key
*.pem
*.crt
*.p12
*.pfx

# Local config overrides (may contain secrets/credentials)
config/settings.local.json
config/homecore.local.toml

# Log files
*.log
logs/

# Runtime data directory
var/

# Node.js
node_modules/
package-lock.json
npm-debug.log*
data/jwt_secret
